{
  "manifest_version": 3,
  "name": "iMerch - Product Info Scraper",
  "version": "2.0",
  "description": "Display ASIN, rank, release date, download, and design analysis tools for Amazon Merch products.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "privacy",
    "scripting",
    "activeTab",
    "downloads",
    "storage",
    "unlimitedStorage",
    "clipboardWrite",
    "proxy",
    "webRequest",
    "webRequestAuthProvider",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.amazon.com/*",
    "https://m.media-amazon.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.ideogram.ai/*",
    "https://ideogram.ai/*",
    "https://accounts.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/s?*",
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/gp/product/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["image-hover.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}